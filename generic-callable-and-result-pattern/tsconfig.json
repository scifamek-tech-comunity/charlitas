{
  "compilerOptions": {
    "baseUrl": "./",
    "rootDir": "./",
    "module": "nodenext",

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,

    "noImplicitReturns": false,
    "noUnusedLocals": false,
    "outDir": "dist",
    "sourceMap": false,
    "strict": true,
    "target": "es2017",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "declaration": true,
    "paths": {},

    "isolatedModules": true
  },
  "compileOnSave": true,
  "include": ["src", "src/index.ts", "tests"],
  "exclude": []
}
